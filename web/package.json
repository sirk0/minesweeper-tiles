{
  "name": "minesweeper-tiles-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript + Three.js rewrite of the Minesweeper Tiles game (M0 scaffold).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:update": "playwright test --update-snapshots",
    "icons": "node scripts/make-icons.mjs"
  },
  "dependencies": {
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.20.1",
    "@types/three": "^0.171.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.0",
    "vitest": "^2.1.0"
  }
}
